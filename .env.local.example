# 各変数の値は .env.local にコピーして設定してください。
# このファイル自体はGitにコミットされます（ダミー値のみ）。

# microCMS（ブログ記事取得用）
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key

# Google Analytics 4 Measurement ID
# - 本番デプロイ環境では必ず設定（CloudFront/S3配信用ビルド）
# - プレビュー環境（Netlify等）では未設定にすること（GA4汚染防止）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
